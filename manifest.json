{
  "manifest_version": 2,
  "name": "HH Grade Analyzer",
  "version": "1.0.0",
  "description": "Автоматический анализ уровня вакансий на hh.ru (Junior/Middle/Senior/Lead)",
  "author": "Alex767",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "*://*.hh.ru/*",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": ["background/analyzer.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.hh.ru/vacancy/*"],
      "js": [
        "data/patterns_db.js",
        "scripts/grade_classifier.js",
        "scripts/page_observer.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_icon": "icons/icon-48.png",
    "default_popup": "popup/popup.html",
    "default_title": "HH Grade Analyzer"
  },
  "web_accessible_resources": [
    "data/*.json"
  ]
}
